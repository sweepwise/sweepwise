[
  {"id": "node-modules", "pattern": "node_modules", "category": "devArtifact", "risk": "rebuildable",
   "context": "JavaScript dependencies installed by npm/pnpm/yarn. Often the largest folder in a project.",
   "restoreNote": "Run pnpm install (or npm install) in the project to recreate."},
  {"id": "python-venv", "pattern": ".venv", "category": "devArtifact", "risk": "rebuildable",
   "context": "Python virtual environment.", "restoreNote": "Recreate with uv sync or python -m venv."},
  {"id": "rust-target", "pattern": "target", "category": "devArtifact", "risk": "rebuildable",
   "context": "Rust/Cargo build output (only flagged when a Cargo.toml sibling exists is NOT checked in v1 — verify before deleting).",
   "restoreNote": "Recreate with cargo build."},
  {"id": "next-build", "pattern": ".next", "category": "devArtifact", "risk": "rebuildable",
   "context": "Next.js build output.", "restoreNote": "Recreate with next build."},
  {"id": "user-caches", "pattern": "~/Library/Caches/*", "category": "cache", "risk": "safe",
   "context": "Per-app cache. Apps regenerate contents automatically; some apps hold caches open while running.",
   "restoreNote": "None needed — regenerated on next app launch."},
  {"id": "shipit-updates", "pattern": "~/Library/Caches/*.ShipIt", "category": "cache", "risk": "safe",
   "context": "Electron auto-updater staging folder (downloaded update copies).",
   "restoreNote": "App re-downloads its next update."},
  {"id": "xcode-derived", "pattern": "~/Library/Developer/Xcode/DerivedData", "category": "devArtifact", "risk": "rebuildable",
   "context": "Xcode build intermediates and indexes.", "restoreNote": "Xcode rebuilds on next build."},
  {"id": "core-simulator", "pattern": "~/Library/Developer/CoreSimulator/Devices", "category": "devArtifact", "risk": "redownload",
   "context": "iOS/watchOS simulator disk images.", "restoreNote": "Xcode recreates simulators on demand (xcrun simctl)."},
  {"id": "ms-playwright", "pattern": "~/Library/Caches/ms-playwright*", "category": "cache", "risk": "redownload",
   "context": "Playwright downloaded browser binaries.", "restoreNote": "Run npx playwright install."},
  {"id": "uv-cache", "pattern": "~/.cache/uv", "category": "cache", "risk": "safe",
   "context": "uv package manager download cache.", "restoreNote": "Repopulated on next uv sync."},
  {"id": "generic-dot-cache", "pattern": "~/.cache/*", "category": "cache", "risk": "safe",
   "context": "XDG tool cache directory.", "restoreNote": "Tools repopulate their caches on next run."},
  {"id": "npm-cache", "pattern": "~/.npm", "category": "cache", "risk": "safe",
   "context": "npm download cache.", "restoreNote": "Repopulated on next npm install."},
  {"id": "pnpm-store", "pattern": "~/Library/pnpm/store*", "category": "cache", "risk": "safe",
   "context": "pnpm content-addressable store. Deleting forces re-download for future installs.",
   "restoreNote": "Repopulated on next pnpm install."},
  {"id": "pre-commit-cache", "pattern": "~/.cache/pre-commit", "category": "cache", "risk": "safe",
   "context": "pre-commit hook environments.", "restoreNote": "Recreated on next pre-commit run."},
  {"id": "ollama-models", "pattern": "~/.ollama/models", "category": "llmModel", "risk": "redownload",
   "context": "Downloaded Ollama LLM weights. Multi-GB files.", "restoreNote": "Re-pull with ollama pull <model>."},
  {"id": "lmstudio", "pattern": "~/.lmstudio", "category": "llmModel", "risk": "redownload",
   "context": "LM Studio models and extensions.", "restoreNote": "Re-download inside LM Studio."},
  {"id": "huggingface-cache", "pattern": "~/.cache/huggingface", "category": "llmModel", "risk": "redownload",
   "context": "Hugging Face model/dataset cache.", "restoreNote": "Re-downloads on next use."},
  {"id": "homebrew-cache", "pattern": "~/Library/Caches/Homebrew", "category": "cache", "risk": "safe",
   "context": "Homebrew downloaded bottles.", "restoreNote": "brew re-downloads as needed; brew cleanup manages this too."},
  {"id": "trash", "pattern": "~/.Trash/*", "category": "trash", "risk": "safe",
   "context": "Already in Trash — user previously chose to delete.", "restoreNote": "None; restore from Trash before emptying if needed."},
  {"id": "stale-downloads", "pattern": "~/Downloads/*", "category": "download", "risk": "userData", "stalenessDays": 90,
   "context": "Download untouched for 90+ days. Often installers and archives already used.",
   "restoreNote": "Re-download from original source if needed — verify before deleting."},
  {"id": "dmg-files", "pattern": "*.dmg", "category": "download", "risk": "redownload", "stalenessDays": 30,
   "context": "Disk image installer; usually already installed.", "restoreNote": "Re-download from the vendor."},
  {"id": "node-gyp-cache", "pattern": "~/Library/Caches/node-gyp", "category": "cache", "risk": "safe",
   "context": "node-gyp downloaded Node headers.", "restoreNote": "Re-downloaded on next native module build."},
  {"id": "codex-cache", "pattern": "~/Library/Caches/com.openai.codex", "category": "cache", "risk": "safe",
   "context": "OpenAI Codex CLI cache.", "restoreNote": "Regenerated on next codex run."},
  {"id": "codex-runtimes", "pattern": "~/.cache/codex-runtimes", "category": "cache", "risk": "safe",
   "context": "Codex CLI runtime downloads.", "restoreNote": "Re-downloaded on next codex run."},
  {"id": "puppeteer-cache", "pattern": "~/.cache/puppeteer", "category": "cache", "risk": "redownload",
   "context": "Puppeteer downloaded Chromium.", "restoreNote": "Re-downloads on next puppeteer install."},
  {"id": "cargo-registry", "pattern": "~/.cargo/registry", "category": "cache", "risk": "safe",
   "context": "Cargo crate download cache.", "restoreNote": "Re-downloads on next cargo build."},
  {"id": "gradle-caches", "pattern": "~/.gradle/caches", "category": "cache", "risk": "safe",
   "context": "Gradle dependency and build cache.", "restoreNote": "Re-downloads on next gradle build."},
  {"id": "cocoapods-cache", "pattern": "~/Library/Caches/CocoaPods", "category": "cache", "risk": "safe",
   "context": "CocoaPods spec/pod cache.", "restoreNote": "Re-downloads on next pod install."},
  {"id": "docker-data", "pattern": "~/Library/Containers/com.docker.docker/Data/vms", "category": "devArtifact", "risk": "userData",
   "context": "Docker Desktop VM disk — contains ALL images, containers, volumes.",
   "restoreNote": "Rebuild/pull images after reset. Volumes are lost — verify nothing precious inside."},
  {"id": "ios-device-support", "pattern": "~/Library/Developer/Xcode/iOS DeviceSupport/*", "category": "devArtifact", "risk": "safe",
   "context": "Debug symbols copied from previously-connected iOS devices.",
   "restoreNote": "Recreated automatically when the device is next connected."}
]
